# ── Base de données Neon (6.0 §2) — requis pour flags runtime, comptes, listes ─
# Chaîne de connexion Postgres (Neon → Dashboard → Connection string, avec ?sslmode=require)
DATABASE_URL=

# ── Catalogue TMDB (D5) — requis pour les données réelles (Lot 2) ──────────────
# Jeton d'accès en lecture v4 (recommandé) : https://www.themoviedb.org/settings/api
TMDB_ACCESS_TOKEN=
# OU clé API v3 (utilisée seulement si TMDB_ACCESS_TOKEN est vide)
TMDB_API_KEY=

# ── Publicité (D6) — défaut OFF (état de lancement) ────────────────────────────
ADS_ENABLED=false
# Flags par emplacement (suivent l'interrupteur global si absents) :
# ADS_DISPLAY_HOME_ENABLED=true
# ADS_DISPLAY_BROWSE_ENABLED=true
# ADS_DISPLAY_FICHE_ENABLED=true
# ADS_NATIVE_RAIL_ENABLED=true
# ADS_VIDEO_PREROLL_ENABLED=true

# ── UGC (D11) — défaut OFF, ne concerne que les rôles non-admin ────────────────
UGC_UPLOAD_ENABLED=false

# ── Authentification (6.1 Lot 2) — requis pour les comptes ─────────────────────
# Générer : openssl rand -base64 32
AUTH_SECRET=
