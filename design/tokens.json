{
  "$description": "CinéScope design tokens — format inspiré de la spéc W3C Design Tokens. Source de vérité éditoriale : docs/phase-4/4.1-design-guidelines.md. Compilé vers tokens.css.",
  "color": {
    "charcoal": { "900": { "$value": "#141118" }, "800": { "$value": "#1C1822" }, "700": { "$value": "#241F2B" }, "600": { "$value": "#2E2837" } },
    "amber": { "400": { "$value": "#F5A623" }, "300": { "$value": "#FFBE4D" } },
    "violet": { "500": { "$value": "#6C4AB6" }, "300": { "$value": "#9B7FD4" } },
    "offwhite": { "$value": "#F2EFF5" },
    "green": { "400": { "$value": "#4CAF7A" } },
    "red": { "400": { "$value": "#E5484D" } },
    "yellow": { "400": { "$value": "#F0C000" } }
  },
  "semantic": {
    "surface": {
      "base": { "$value": "{color.charcoal.900}" },
      "raised": { "$value": "{color.charcoal.800}" },
      "overlay": { "$value": "{color.charcoal.700}" },
      "interactive": { "$value": "{color.charcoal.600}" },
      "sponsored": { "$value": "violet-500 @ 6% over charcoal-800" }
    },
    "text": {
      "primary": { "$value": "{color.offwhite} @ 87%" },
      "secondary": { "$value": "{color.offwhite} @ 60%" },
      "disabled": { "$value": "{color.offwhite} @ 38%" }
    },
    "accent": {
      "brand": { "$value": "{color.amber.400}" },
      "brandHover": { "$value": "{color.amber.300}" },
      "onAccent": { "$value": "#1A1408" }
    },
    "status": {
      "success": { "$value": "{color.green.400}" },
      "danger": { "$value": "{color.red.400}" },
      "warning": { "$value": "{color.yellow.400}" }
    },
    "ad": {
      "labelBg": { "$value": "{color.violet.500} @ 15%" },
      "labelText": { "$value": "{color.violet.300}" }
    }
  },
  "font": {
    "display": { "$value": "Space Grotesk" },
    "text": { "$value": "Inter" },
    "mono": { "$value": "JetBrains Mono" }
  },
  "space": { "1": { "$value": "4px" }, "2": { "$value": "8px" }, "3": { "$value": "12px" }, "4": { "$value": "16px" }, "5": { "$value": "24px" }, "6": { "$value": "32px" }, "7": { "$value": "40px" }, "8": { "$value": "48px" }, "10": { "$value": "64px" }, "12": { "$value": "96px" } },
  "radius": { "s": { "$value": "6px" }, "m": { "$value": "10px" }, "l": { "$value": "16px" }, "full": { "$value": "999px" } },
  "motion": {
    "duration": { "fast": { "$value": "150ms" }, "base": { "$value": "250ms" }, "slow": { "$value": "350ms" } },
    "easing": { "enter": { "$value": "cubic-bezier(0.2, 0, 0, 1)" }, "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)" } }
  },
  "breakpoint": { "sm": { "$value": "360px" }, "md": { "$value": "768px" }, "lg": { "$value": "1024px" }, "xl": { "$value": "1440px" }, "tv": { "$value": "1920px" } }
}
